<avalonia:Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DiagramLab.Desktop.Converters"
             xmlns:avalonia="clr-namespace:Avalonia;assembly=Avalonia.Controls"
             x:Class="DiagramLab.Desktop.App"
             RequestedThemeVariant="Light">
    <Application.Resources>
        <converters:ArrayToRelativeRectConverter x:Key="ArrayToRelativeRectConverter" />
    </Application.Resources>
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</avalonia:Application>